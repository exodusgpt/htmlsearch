{
  "name": "narrative-site-crawler",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "crawl": "node src/crawl-narrative.js",
    "crawl:headed": "HEADLESS=false node src/crawl-narrative.js",
    "summarize": "SUMMARIZE_ONLY=true node src/crawl-narrative.js",
    "scan": "PLAYWRIGHT_BROWSERS_PATH=0 node src/scan-identity.js",
    "scan:headed": "PLAYWRIGHT_BROWSERS_PATH=0 HEADLESS=false node src/scan-identity.js",
    "dev": "PLAYWRIGHT_BROWSERS_PATH=0 node src/server.js",
    "start": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium && PLAYWRIGHT_BROWSERS_PATH=0 node src/server.js",
    "postinstall": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium",
    "render:build": "PLAYWRIGHT_BROWSERS_PATH=0 npm install && PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install --with-deps chromium",
    "render:start": "npm start"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  }
}
